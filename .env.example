# ScrapeX Configuration
# Copy this to .env and fill in your values

# OpenRouter API Key — enables the research agent (/agent), search answers
# (include_answer), and AI extraction (/extract).
# Get one free at: https://openrouter.ai/keys
SCRAPEX_OPENROUTER_API_KEY=

# AI Model for extraction/answers (default: google/gemini-flash-1.5)
# Options: openai/gpt-4o, anthropic/claude-sonnet-5, google/gemini-flash-1.5
SCRAPEX_AI_MODEL=google/gemini-flash-1.5

# Model for the research agent — must support tool calling.
# Falls back to SCRAPEX_AI_MODEL when unset.
# SCRAPEX_AGENT_MODEL=anthropic/claude-sonnet-5

# Tool-loop budget for depth="advanced" agent runs
# SCRAPEX_AGENT_MAX_STEPS=8

# API auth — comma-separated keys. Auth is enforced ONLY when set.
# Clients send "Authorization: Bearer <key>" or "X-API-Key: <key>".
# SCRAPEX_API_KEYS=sx-my-secret-key

# Rate limiting (requests per minute per client IP)
# SCRAPEX_RATE_LIMIT_REQUESTS=60

# Social response cache TTL in seconds
# SCRAPEX_CACHE_TTL=300

# Per-platform request timeout in seconds
# SCRAPEX_SOCIAL_TIMEOUT=20

# Dataset runs (Apify-style background jobs — POST /api/v1/runs)
# SCRAPEX_RUN_TIME_BUDGET=240     # seconds a run may spend paginating
# SCRAPEX_RUN_MAX_ITEMS=1000      # hard cap on max_items per run
# SCRAPEX_RUN_PAGE_DELAY=0.5      # politeness delay between pages
# SCRAPEX_RUN_HISTORY_LIMIT=200   # runs/datasets kept in memory

# Nitter mirrors for Twitter timelines/search (comma-separated).
# Public mirrors are mostly dead; point this at one you trust to re-enable timelines.
# SCRAPEX_NITTER_INSTANCES=https://nitter.example.com

# Debug mode
SCRAPEX_DEBUG=false

# Optional: Proxy URL for scraping (rotating proxy recommended)
# SCRAPEX_PROXY_URL=http://user:pass@proxy:8080
