# ScrapeX Configuration
# Copy this to .env and fill in your values

# OpenRouter API Key (for AI extraction features)
# Get one free at: https://openrouter.ai/keys
SCRAPEX_OPENROUTER_API_KEY=

# AI Model for extraction (default: google/gemini-flash-1.5)
# Options: openai/gpt-4o, anthropic/claude-sonnet-4, google/gemini-flash-1.5
SCRAPEX_AI_MODEL=google/gemini-flash-1.5

# Debug mode
SCRAPEX_DEBUG=false

# Optional: Proxy URL for scraping (rotating proxy recommended)
# SCRAPEX_PROXY_URL=http://user:pass@proxy:8080
